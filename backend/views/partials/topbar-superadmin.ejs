<div class="modal fade" id="createAccount" data-bs-backdrop="static" aria-labelledby="exampleModalToggleLabel" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h4 class="modal-title mt-0" id="exampleModalToggleLabel">Create Account</h4>
          <button type="button" class="btn-close closebtn"  data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
            <form action="" id="bootstrap-form" novalidate>
                <div class="row g-2">
                  <div class="col" id="form-fname">
                    <label class="text-black fw-bold mb-1" for="projectName">First Name <span class="text-danger">*</span></label>
                    <input type="text" id="fname" class="form-control " placeholder="First name">
                    <div class="invalid-feedback" id="invalid-fistname">
                      Please fill in your email!
                    </div>
                  </div>
                  <div class="col" id="form-lname">
                    <label class="text-black fw-bold mb-1" for="projectName">Last Name <span class="text-danger">*</span></label>
                    <input type="text" id="lname"  class="form-control" placeholder="Last name">
                    <div class="invalid-feedback" id="invalid-lastname">
                      Please fill in your email!
                    </div>
                  </div>
                </div>
                 <div class="col mt-3" id="form-lname">
                    <label class="text-black fw-bold mb-1" for="projectName">User Name <span class="text-danger">*</span></label>
                    <input type="text" id="username"  class="form-control" placeholder="firstname.lastname">
                    <div class="invalid-feedback" id="invalid-username">
                      Please fill in your email!
                    </div>
                  </div>
                <div class="row g-2 mt-3">
                  <div class="col" id="form-email">
                    <label class="text-black fw-bold mb-1" for="projectName">Email <span class="text-danger">*</span></label>
                    <input type="text" id="email" class="form-control " placeholder="Email">
                    <div class="invalid-feedback" id="invalid-email">
                      Please fill in your email!
                    </div>
                  </div>
                  <div class="col" id="form-roles">
                    <label class="text-black fw-bold mb-1" for="projectName">Select Role <span class="text-danger">*</span></label>
                    <select class="form-select select2" id="select-row" placeholder="Select Roles" autocomplete="off">
                        <option disabled selected value="">Roles</option>
                        <option value="1">Super Admin</option>
                        <option value="2">Admin</option>
                        <option value="3">Member</option>
                    </select>
                    <div class="invalid-feedback" id="invalid-roles">
                        Please fill in your email!
                    </div>
                </div>
                
                </div>
                <div class="row g-2 mt-3 wrapper">
                   <div class="col-6">
                    <div class="position-relative">
                      <div class="col" id="form-password">
                        <label class="text-black fw-bold mb-1 d-flex" for="projectName">Password <p class="text-danger mb-0 ms-1">*</p></label>
                        <input type="password" class="form-control " id="passwords" placeholder="Password">
                        <span class="show-btn"><i class='fas fa-eye eye-custom fs-6'></i></span>
                        <div class="invalid-feedback" id="invalid-password">
                          Password must be at least 8 characters long.
                        </div>
                      </div>
                      
                    </div>
                   </div>
                     <div class="col-6">
                      <div class="position-relative">
                        <div class="col " id="form-cpassword">
                          <label class="text-black fw-bold mb-1 d-flex" for="projectName">Confirm Password <p class="text-danger mb-0 ms-1">*</p></label>
                          <input type="password" class="form-control " id="cpassword" placeholder="Confirm Password">
                          <span class="show-btn"><i class='fas fa-eye eye-custom fs-6'></i></span>
                          <div class="invalid-feedback" id="invalid-cpassword">
                            Please fill in your email!
                          </div>
                        </div>
                       </div>
                     </div>
                </div>

                <div class="row g-2 mt-3 " id="form-project">
                  <div class="col">
                    <label class="text-black fw-bold mb-1" for="projectName">Select Project</label>
                    <select class="form-select select2" id="select-project" placeholder="Select Project" >
                     
                    </select>
                    <div class="invalid-feedback" id="invalid-project">
                      Please fill in your email!
                    </div>
                  </div>
                </div>
                <div class="modal-footer p-0 mt-3">
                  <button type="button" class="btn btn-secondary closebtn" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    <button onclick="register()" type="button" class="btn btn-primary" id="btn-create-account">
