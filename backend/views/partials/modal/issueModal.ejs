<!-- / Update Issue Note -->

<div class="modal fade" id="editIssueNote" aria-hidden="true" aria-labelledby="editIssueNoteLabel" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom py-3">
                <h1 class="modal-title fs-5 text-b font-weight-bold" id="editIssueNoteLabel">Edit Note</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="py-2" id="issue-note-prop">

                </div>
                <div class="py-3">
                    <div id="notetoolbar-container" class="border">
                        <span class="ql-formats py-3">
                            <select class="ql-font"></select>
                            <select class="ql-size"></select>
                        </span>
                        <span class="ql-formats">
                            <button class="ql-bold"></button>
                            <button class="ql-italic"></button>
                            <button class="ql-underline"></button>
                            <button class="ql-strike"></button>
                        </span>
                        <span class="ql-formats">
                            <select class="ql-color"></select>
                            <select class="ql-background"></select>
                        </span>
                        <span class="ql-formats">
                            <button class="ql-script" value="sub"></button>
                            <button class="ql-script" value="super"></button>
                        </span>
                        <span class="ql-formats">
                            <button class="ql-header" value="1"></button>
                            <button class="ql-header" value="2"></button>
                        </span>
                        <span class="ql-formats">
                            <button class="ql-list" value="ordered"></button>
                            <button class="ql-list" value="bullet"></button>
                            <button class="ql-indent" value="-1"></button>
                            <button class="ql-indent" value="+1"></button>
                        </span>
                        <span class="ql-formats">
                            <select class="ql-align"></select>
                        </span>
                        <span class="ql-formats">
                            <button class="ql-link"></button>
                            <button class="ql-image"></button>
                            <button class="ql-clean"></button>
                        </span>
                    </div>
                    <div id="editnote-editor" class="py-3 px-4">
                    </div>
                </div>

            </div>
            <div class="modal-footer pt-0 pb-4">
                <button class="btn btn-secondary" data-bs-target="#editIssueNote" data-bs-toggle="modal">Cancel</button>
                <button class="btn btn-primary border-2 d-flex align-items-center" data-id="" data-issue="" id="btn-editIssueNote"
                    onclick="editIssueNoteClicked()">
                    <div id="btn-edit-issue-note-spinner" class="spinner-border text-white spinner-border-sm me-2 d-none" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span id="btn-edit-issue-note-text">Save</span>
                </button>
            </div>
        </div>
    </div>
</div>