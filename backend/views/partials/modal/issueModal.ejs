<!-- Create Issue -->

<div class="modal fade" id="createIssue" aria-hidden="true" aria-labelledby="createIssueLabel" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom py-3">
                <h1 class="modal-title fs-5 text-b font-weight-bold" id="createIssueLabel">Create New Issue</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="py-2" id="modal-main-compo">

                </div>
                <form action="" id="bootstrap-form" novalidate>
                    <div class="row g-3 py-4">
                        <div class="col-12">
                            <input type="text" id="createIssueName" class="form-control" oninput="onInputRequireString('createIssueName', 'createIssueNameValidate', 255, {
                                require: 'Issue name is required..!',
                                needdata: 'Issue name need to be more than 1 characters!',
                                overdata: 'Issue name cannot be more than 255 characters..!',
                            })" placeholder="Issue title">
                            <div class="mt-1 px-2 text-danger d-none" id="createIssueNameValidate">

                            </div>
                        </div>
                        <div class="col-12">
                            <textarea name="description" id="createIssueDescription" placeholder="Issue description"
                                class="form-control" style="height: 110px;"></textarea>
                        </div>
                    </div>
                </form>
                <div class="col-12 h-100 d-flex flex-wrap justify-content-start align-items-center"
                    id="create-issue-property">

                </div>
            </div>
            <div class="modal-footer pt-0 pb-4">
                <button onclick="register()" class="btn btn-secondary border-2" data-bs-target="#createIssue"
                    data-bs-toggle="modal">Cancel</button>
                <button class="btn btn-primary border-2 d-flex align-items-center" id="btn-create-issue"
                    onclick="createIssueClicked()">
                    <div id="btn-create-issue-spinner" class="spinner-border text-white spinner-border-sm me-2 d-none" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span id="btn-create-issue-text">Save</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- / Create Issue -->

<!-- Update Issue -->

<div class="modal fade" id="editIssue" aria-hidden="true" aria-labelledby="createIssueLabel" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom py-3">
                <h1 class="modal-title fs-5 text-b font-weight-bold" id="editIssueLabel">Edit Issue</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="py-2" id="modal-update-main-compo">

                </div>
                <form action="" id="bootstrap-form" novalidate>
                    <div class="row g-3 py-4">
                        <div class="col-12">
                            <input type="text" id="updateIssueName" class="form-control" oninput="onInputRequireString('updateIssueName', 'updateIssueNameValidate', 255, {
                                require: 'Issue name is required..!',
                                needdata: 'Issue name need to be more than 1 characters!',
                                overdata: 'Issue name cannot be more than 255 characters..!',
                            })" placeholder="Issue title">
                            <div class="mt-1 px-2 text-danger d-none" id="updateIssueNameValidate">

                            </div>
                        </div>
                        <div class="col-12">
                            <textarea name="description" id="updateIssueDescription" placeholder="Issue description"
                                class="form-control" style="height: 110px;"></textarea>
                        </div>
                        <div class="col-12 d-flex align-items-center py-2" id="updateIssueProgressModal">

                        </div>
                    </div>
                </form>
                <div class="col-12 h-100 d-flex flex-wrap justify-content-start align-items-center"
                    id="update-issue-property">

                </div>
            </div>
            <div class="modal-footer pt-0 pb-4">
                <button onclick="register()" class="btn btn-secondary border-2" data-bs-target="#editIssue"
                    data-bs-toggle="modal">Cancel</button>
                <button class="btn btn-primary border-2 d-flex align-items-center" id="btn-edit-issue"
                    onclick="updateIssueClicked()">
                    <div id="btn-edit-issue-spinner" class="spinner-border text-white spinner-border-sm me-2 d-none" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span id="btn-edit-issue-text">Save</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- / Update Issue -->

