<!-- Edit Modal -->
<div class="modal fade" id="exampleModalEdit" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
aria-labelledby="viewDetailModalLabel" aria-hidden="true">
<div class="modal-dialog modal-dialog-centered">
  <div class="modal-content">
    <div class="modal-header py-3">

      <h4 class="modal-title pt-0 mt-0" id="exampleModalEdit">Edit Account</h4>
      <button type="button" class="btn-close mt-1" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>
    <div class="modal-body">
      <form>
        <div class="row g-2">
          <div class="col mb-3">
            <input type="text" id="editfname" class="form-control "
              placeholder="First name" disabled>
          </div>
          <div class="col">
            <input type="text" id="editlname" class="form-control "
              placeholder="Last name" disabled>
          </div>
        </div>
        <div class="row g-2 mb-3">
          <div class="col">
            <input type="text" id="editusername" class="form-control " placeholder="Username"
              disabled>
          </div>
           <div class="col">
            <input type="text" id="editemail" class="form-control " placeholder="Email"
              disabled>
          </div>
        </div>
        <div class="form-row mb-3">
          <div class="col-12">
            <div class="col px-0">
              <select class="form-select select2" id="editroles">
                <option disabled selected value="">Roles</option>
                <option value="1">KOT</option>
                <option value="2">WEB</option>
                <option value="3">DODO</option>
              </select>
            </div>
          </div>
        </div>
      </form>
    </div>
    <div class="modal-footer border-0">
      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
      <button type="button" class="btn btn-primary d-flex align-items-center" id="btn-edit-account" onclick="editUser(this)">
        <div id="btn-edit-account-spinner" class="spinner-border text-white spinner-border-sm me-2 d-none" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
        <span id="btn-edit-account-text">Save</span>
      </button>
    </div>
  </div>
</div>
</div>

<!--end modal table user -->


<!-- changePassword -->

<div class="modal fade" id="changePasswordModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
aria-labelledby="viewDetailModalLabel">
<div class="modal-dialog modal-dialog-centered">
  <div class="modal-content">
    <div class="modal-header py-3">

      <h4 class="modal-title pt-0 mt-0" id="changePassword">Change Password</h4>
      <button type="button" class="btn-close mt-1" data-bs-dismiss="modal" aria-label="Close" onclick="removeValidPassowrd()"></button>
    </div>
    <div class="modal-body">
      <form>
        <div class="form-row mb-3">
          <div class="col-12">
            <input type="text" id="getemail" class="form-control " placeholder="Email"
              disabled>
          </div>
          <div class="col-12 mt-3" >
            <div class="col password-input-wrapper" id="form-password">
              <input type="password" id="changePw" class="form-control" placeholder="New Password">
              <span class="show-btn"><i class="fas fa-eye"></i></span>
              <div class="invalid-feedback mb-2" id="invalid-pass">
                Please fill in your password!
              </div>
            </div>
          </div>
        </div>
      </form>
    </div>
    <div class="modal-footer border-0">
      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="removeValidPassowrd()">Cancel</button>
      <button type="button" class="btn btn-primary d-flex align-items-center" id="btn-save-change-pass" onclick="saveChangePassword(this)">
        <div id="btn-save-change-pass-spinner" class="spinner-border text-white spinner-border-sm me-2 d-none" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
        <span id="btn-save-change-pass-text">Save</span>
      </button>
    </div>
  </div>
</div>
</div>

<!-- modal forgot password -->

<div class="modal fade" id="forgotpassword" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1"
aria-labelledby="viewDetailModalLabel">
<div class="modal-dialog modal-dialog-centered">
  <div class="modal-content">
    <div class="modal-header py-3">
      <h4 class="modal-title pt-0 mt-0" id="changePassword">Forgot Password</h4>
      <button type="button" class="btn-close mt-1" data-bs-dismiss="modal" aria-label="Close" onclick="removeForgot()"></button>
    </div>
    <div class="modal-body pt-1">
      <p class="mb-2">Please verify your email for request new password.</p>
      <p class="mt-2 mb-3 text-danger">( Please, wait a few time for message sent to your email. )</p>
      <form>
        <div class="form-row">
          <div class="col-12">
            <div class="col">
              <input type="email" id="forgotEmail" class="form-control " placeholder="Email">
            <div class="invalid-feedback" id="invalid-forgot">
              Please fill in your email!
            </div>
            </div>
          </div>
        </div>
      </form>
    </div>
    <div class="modal-footer border-0">
      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="removeForgot()">Cancel</button>
      <button type="button" id="btn-request-new-pass" class="btn btn-primary d-flex align-items-center" onclick="forgotpassword()">
        <div id="btn-request-new-pass-spinner" class="spinner-border text-white spinner-border-sm me-2 d-none" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
        <span id="btn-request-new-pass-text">Send</span>
      </button>
    </div>
  </div>
</div>
</div>