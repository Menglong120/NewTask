<!DOCTYPE html>
<html lang="en">

<%- include('../partials/head')  %>

<body class="login-user position-relative">
  <div id="page-loader" aria-label="Loading">
    <div class="spinner"></div>
</div>
  <div class="container" id="main-content">
    <div class="row align-items-center justify-content-center">
      <div class="col-xl-5 col-lg-4 col-md-10 res-login">
        <div class="round-logo d-flex align-items-center">
          <div class="logo">
            <img src="/img/login/book.png" alt="">
          </div>
        </div>
        <div class="img-wave">
          <img src="/img/login/wave.png" alt="">
        </div>
        <div class="img-plan">
          <img src="/img/login/plan.png" alt="">
        </div>
        <div class="img-book">
          <img src="/img/login/book.png" alt="">
        </div>
        <div class="img-time">
          <img src="/img/login/time.png" alt="">
        </div>
        <div class="img-time">
          <img src="/img/login/time.png" alt="">
        </div>
        <div class="img-light">
          <img src="/img/login/light.png" alt="">
        </div>
        <div class="img-gear">
          <img src="/img/login/gear.png" alt="">
        </div>
        <div class="img-line">
          <img src="/img/login/line.png" alt="">
        </div>
        <div class="card mb-4 mt-5" style="box-shadow: rgba(100, 100, 111, 0.09) 0px 7px 29px 0px;">
          <div class="card-header position-relative mb-0">
            <div class="">
             <img style="width: 170px;" src="/img/Logo NSM Tech.V2-Confirm.png" alt="">
           </div>
            <h3 class="mb-0 text-center pt-3 pb-1">Login</h3>
            <!-- <div class="img-load">
              <img src="/img/login/load.png" alt="">
            </div> -->
            <div class="img-clip">
              <img src="/img/login/clip.png" alt="">
            </div>
          </div>
          <div class="card-body">
            <h4 class="mb-2">Welcome to <a href="/index">NSM!</a> 👋</h4>
            <p class="mb-0">Please sign-in to your account as user</p>
            <form id="form-login">
              <div class=" wrapper">
                  <div class="input-box mt-3" id="form-email">
                    <input type="text" id="username" required>
                    <label class="labelemail" for="email">User Name</label>
                  </div>
                  <div class="invalid-feedback" id="invalid-username">
                    Please fill in your email!
                  </div>
                  <div class="input-box mb-2 mt-4" id="form-password" >
                    <input type="password" id="password" required>
                    <label for="labelpass">Password</label>
                    <span class="show-btn"><i class="fas fa-eye"></i></span>
                  </div>
                  <div class="invalid-feedback mb-2 " id="invalid-pass">
                    Please fill in your password!
                  </div>
                </div>
              <div class="d-flex align-items-center justify-content-between mb-5 justify-between">
                  <div class="ms-1 mt-1">
                      <input type="checkbox" id="remember-me" class="form-check-input custom-checkbox mt-2" style="transform: scale(1.5); width: 12px; height: 12px;">
                      <label class="form-check-label ms-2 mt-1 fw-normal" for="remember-me" style="font-size: 14px;">Remember Me</label>
                      <div id="checkbox-error" class="error invalid-feedback fs-6"></div>
                    </div>
                    <!-- <div class="ms-1 mt-1">
                        <a href="javascript:void(0)"><p class="mb-0 mt-2 py-2" id="forgotid" data-bs-toggle="modal" data-bs-target="#forgotpassword">Forgot Password ?</p></a>
                    </div> -->
              </div>
              <button type="button" class="btn btn-primary w-100 py-2 fs-5 mb-3 d-flex align-items-center justify-content-center" id="login" onclick="btnlogin()">
                <div id="login-spinner" class="spinner-border text-white spinner-border-sm me-2 d-none" role="status">
                  <span class="visually-hidden">Loading...</span>
                </div>
                <span id="login-text">Log In</span>
              </button>
          </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="/vendor/libs/jquery/jquery.js"></script>
    <script src="/vendor/libs/popper/popper.js"></script>
    <script src="/vendor/js/bootstrap.js"></script>
    <script src="/vendor/libs/perfect-scrollbar/perfect-scrollbar.js"></script>
    <script src="/vendor/select2/select2.min.js"></script>
    <script src="/vendor/sweetAlert2/sweetalert2@11.js"></script>
    <script src="/vendor/libs/apex-charts/apexcharts.js"></script>
    <script src="/vendor/js/menu.js"></script>
    <script src="/js/spinner.js"></script>

    <script src="/js/fetchApi.js"></script>
    <script src="/js/btnLoading.js"></script>
    <script src="/js/loginUser.js"></script>
    <script src="/js/validation.js"></script>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
    // Select the "show button" for the password field
    const showBtn = document.querySelector("#form-password .show-btn");
    const passField = document.querySelector("#form-password input[type='password']");
  
    if (showBtn && passField) {
      showBtn.addEventListener("click", () => {
        const icon = showBtn.querySelector("i");
        if (passField.type === "password") {
          passField.type = "text"; // Show the password
          icon.classList.replace("fa-eye", "fa-eye-slash");
        } else {
          passField.type = "password"; // Hide the password
          icon.classList.replace("fa-eye-slash", "fa-eye");
        }
      });
    }
  });
  
    </script>
</body>
</html>
