<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NSM Task Management System</title>

  <link rel="icon" type="image/png" href="/img/Logo NSM Tech.V2-Confirm.png">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/vendor/fontawesome-free-6.7.2-web/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/vendor/sweetAlert2/sweetalert2.min.css">
  <link rel="stylesheet" href="/vendor/css/core.css" class="template-customizer-core-css">
  <link rel="stylesheet" href="/vendor/css/theme-default.css" class="template-customizer-theme-css">
  <link rel="stylesheet" href="/css/demo.css">
  <link rel="stylesheet" href="/vendor/css/pages/page-auth.css" />
</head>

<body class="superadmin">
  <div id="page-loader" aria-label="Loading">
    <div class="spinner"></div>
</div>
  <div class="login_form container authentication-wrapper authentication-basic" id="main-content">
   <div class="authentication-inner">
    <div class="card border-0">
      <div class="card-body bg-transparent border-0">
        <!-- Logo -->
        <div class="app-brand justify-content-center">
          <a href="javascript:void(0)" class="app-brand-link gap-2">
            <span class="app-brand-logo demo">
             <!-- logo -->
            </span>
           <div class="">
             <img style="width: 170px;" src="/img/Logo NSM Tech.V2-Confirm.png" alt="">
           </div>
          </a>
        </div>
        <!-- /Logo -->
        <h4 class="mb-2">Welcome to NSM! 👋</h4>
        <p class="mb-4">Please sign-in to your account as superadmin</p>

        <form id="formAuthentication" class="mb-3" action="index.html" method="POST">
          <div class=" wrapper">
            <div class="input-box mt-4" id="form-email">
              <input type="text" id="username" required>
              <label class="labelemail" for="username">User Name</label>
            </div>
            <div class="invalid-feedback" id="invalid-username">
              Please fill in your email!
            </div>
            <div class="input-box mb-2 mt-4" id="form-password">
              <input type="password" id="password" required>
              <label for="labelpass">Password</label>
              <span class="show-btn"><i class="fas fa-eye"></i></span>
            </div>
            <div class="invalid-feedback mb-2" id="invalid-pass">
              Please fill in your password!
            </div>
          </div>
          <div class=" form-check" style="margin-bottom: 30px;">
            <div class="ml-1">
              <input type="checkbox" id="remember-me" class="form-check-input custom-checkbox mt-2"
                style="transform: scale(1.5); width: 12px; height: 12px;">
              <label class="form-check-label" for="remember-me" style="font-size: 13px; margin-top: 5px;">Remember Me</label>
              <div id="checkbox-error" class="error invalid-feedback fs-6"></div>
            </div>
          </div>
          <div class="mb-3">
            <button type="button" onclick="login()" class="btn d-grid w-100 btn-primary d-flex align-items-center justify-content-center" id="btnlogin">
              <div id="btnlogin-spinner" class="spinner-border text-white spinner-border-sm me-2 d-none" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
              <span id="btnlogin-text">Log In</span>
            </button>
          </div>
        </form>
      </div>
    </div>
   </div>
  </div>

  <script src="/js/spinner.js"></script>
  <script src="/js/fetchApi.js"></script>
  <script src="/js/btnLoading.js"></script>
  <script src="/js/validation.js"></script>
  <script src="/js/superadmin.js"></script>
  <script src="/vendor/sweetAlert2/sweetalert2@11.js"></script>
  <!-- <script src="/js/script.js"></script> -->

  <script>
    document.addEventListener("DOMContentLoaded", () => {
  // Select the "show button" for the password field
  const showBtn = document.querySelector("#form-password .show-btn");
  const passField = document.querySelector("#form-password input[type='password']");

  if (showBtn && passField) {
    showBtn.addEventListener("click", () => {
      const icon = showBtn.querySelector("i");
      if (passField.type === "password") {
        passField.type = "text"; // Show the password
        icon.classList.replace("fa-eye", "fa-eye-slash");
      } else {
        passField.type = "password"; // Hide the password
        icon.classList.replace("fa-eye-slash", "fa-eye");
      }
    });
  }
});

  </script>

</body>

</html>